# Run: kubectl create secret generic argus-secrets -n argus \
#   --from-literal=database-url='postgresql://argus:PASSWORD@127.0.0.1:5432/argus' \
#   --from-literal=setup-secret='YOUR_SETUP_SECRET'
apiVersion: v1
kind: Secret
metadata:
  name: argus-secrets
  namespace: argus
type: Opaque
stringData:
  database-url: "postgresql://argus:PASSWORD@127.0.0.1:5432/argus"
  setup-secret: "generate_with_openssl_rand_hex_32"
