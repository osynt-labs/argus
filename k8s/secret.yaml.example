# Create with:
# kubectl create secret generic argus-secrets -n argus \
#   --from-literal=database-url='postgresql://argus:PASSWORD@127.0.0.1:5432/argus' \
#   --from-literal=setup-secret='...' \
#   --from-literal=nextauth-secret='...' \
#   --from-literal=google-client-id='....apps.googleusercontent.com' \
#   --from-literal=google-client-secret='...' \
#   --from-literal=allowed-email='itay.van.dar@gmail.com'
apiVersion: v1
kind: Secret
metadata:
  name: argus-secrets
  namespace: argus
type: Opaque
stringData:
  database-url:         "postgresql://argus:PASSWORD@127.0.0.1:5432/argus"
  setup-secret:         "openssl rand -hex 32"
  nextauth-secret:      "openssl rand -hex 32"
  nextauth-url:         "https://argus.osynt.ai"
  google-client-id:     "your_client_id.apps.googleusercontent.com"
  google-client-secret: "your_client_secret"
  allowed-email:        "itay.van.dar@gmail.com"
