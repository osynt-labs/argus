# =============================================================================
# Argus — Environment Variables
#
# Copy this file to .env and fill in real values:
#   cp .env.example .env
#
# In production (GKE) these are injected from GCP Secret Manager via the
# "argus-secrets" Kubernetes secret (see terraform/secrets.tf).
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# PostgreSQL connection string used by Prisma (adapter-pg) at runtime and for
# migrations (prisma.config.ts).
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL="postgresql://argus:changeme@localhost:5432/argus"

# -----------------------------------------------------------------------------
# Authentication (NextAuth.js / Auth.js)
# -----------------------------------------------------------------------------

# A random secret used to sign/encrypt JWTs and session cookies.
# Generate one with:  openssl rand -hex 32
NEXTAUTH_SECRET="generate-a-random-hex-string-here"

# The canonical URL of the application (used by NextAuth for callbacks).
# In production this is https://argus.osynt.ai
NEXTAUTH_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Credentials provider — single-user login
# -----------------------------------------------------------------------------

# The username accepted by the credentials provider.
# REQUIRED — the app will throw if this is missing.
ARGUS_USERNAME=""

# The password accepted by the credentials provider.
# REQUIRED — the app will throw if this is missing.
ARGUS_PASSWORD="changeme"

# -----------------------------------------------------------------------------
# Setup / bootstrap
# -----------------------------------------------------------------------------

# A shared secret required in the x-setup-secret header when calling
# POST /api/setup to create the first API key.
# Generate one with:  openssl rand -hex 32
SETUP_SECRET="generate-a-random-hex-string-here"

# -----------------------------------------------------------------------------
# Node.js
# -----------------------------------------------------------------------------

# Standard Node environment. Set to "production" in deployed environments.
# When not "production", Prisma client is cached on globalThis to avoid
# exhausting connections during hot-reloads.
# NODE_ENV="development"
